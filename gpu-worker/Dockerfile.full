# Avatar Factory GPU Worker - Full MuseTalk Support
# Based on OpenMMLab pre-built image with mmcv/mmdet/mmpose

FROM openmmlab/mmdetection:py38-torch2.0.0-cu118 AS base

# Upgrade to Python 3.11 in separate stage (complex)
# OR keep Python 3.8/3.9 and adjust dependencies

# Note: This is a starting point. OpenMMLab images come with mmcv/mmdet/mmpose pre-installed
# but may have older Python/PyTorch versions.

# For production use, consider:
# 1. Use OpenMMLab's official images and adapt Avatar Factory to their versions
# 2. Build custom image with Anaconda and install all packages via conda
# 3. Use multi-stage build with compilation environment

# Set environment
ENV PYTHONUNBUFFERED=1
ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /app

# Install additional dependencies
RUN apt-get update && apt-get install -y \
    ffmpeg \
    libsm6 \
    libxext6 \
    wget \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Upgrade pip
RUN pip install --no-cache-dir --upgrade pip

# Install PyTorch 2.7.0 (may conflict with mmcv)
# RUN pip install --no-cache-dir \
#     torch==2.7.0+cu118 \
#     torchvision==0.22.0+cu118 \
#     --index-url https://download.pytorch.org/whl/cu118

# Copy and install Python dependencies
COPY requirements.txt pyproject.toml ./
RUN pip install --no-cache-dir -r requirements.txt

# Install project
COPY . .
RUN pip install --no-cache-dir -e .

# Setup MuseTalk
RUN if [ ! -d "MuseTalk" ]; then \
    git clone https://github.com/TMElyralab/MuseTalk.git && \
    pip install --no-cache-dir -r musetalk-requirements.txt && \
    pip install --no-cache-dir \
        git+https://github.com/TMElyralab/MMCM.git@main \
        git+https://github.com/TMElyralab/controlnet_aux.git@tme \
        git+https://github.com/tencent-ailab/IP-Adapter.git@main \
        git+https://github.com/openai/CLIP.git@main; \
    fi

# Create temp directory
RUN mkdir -p /tmp/avatar-factory && chmod 777 /tmp/avatar-factory

# Expose port
EXPOSE 8001

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=300s --retries=3 \
    CMD curl -f http://localhost:8001/health || exit 1

# Run server
CMD ["python", "server.py"]
