# GPU Worker Environment Configuration
# Copy this file to .env and fill in your values

# HuggingFace API Token (optional)
# Used for faster model downloads and higher rate limits
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=your_token_here

# GPU Worker API Key (required)
# Used for authenticating requests to the GPU worker
API_KEY=your-secret-api-key-change-this

# GPU Worker Port (optional, default: 8001)
PORT=8001

# Log Level (optional, default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
