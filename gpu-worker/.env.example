# Avatar Factory GPU Worker - Environment Variables

# GPU Server API Key (измените!)
GPU_API_KEY=your-secret-gpu-key-change-this

# Polza.ai API Key (для video generation)
# Получить на: https://polza.ai/dashboard/api-keys
POLZA_API_KEY=

# Server Configuration
HOST=0.0.0.0
PORT=8001

# Optional: Model paths (если хотите использовать локальные модели)
# MODELS_DIR=/path/to/models
