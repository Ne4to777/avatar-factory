# Database
DATABASE_URL="postgresql://avatar:avatar_password@localhost:5432/avatar_factory"

# Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_URL="redis://localhost:6379"

# MinIO (S3-compatible storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin123"
MINIO_BUCKET="avatar-videos"
MINIO_USE_SSL="false"
MINIO_PUBLIC_URL="http://localhost:9000"

# GPU Server (стационарный ПК)
GPU_SERVER_URL="http://192.168.1.100:8001"
GPU_API_KEY="your-secret-gpu-key-change-this"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WS_URL="ws://localhost:3000"

# Auth (опционально - добавьте если нужна аутентификация)
# NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# NEXTAUTH_URL="http://localhost:3000"

# OpenAI (опционально - если захотите добавить AI-улучшения)
# OPENAI_API_KEY="sk-..."

# Sentry (опционально - мониторинг ошибок)
# SENTRY_DSN="https://..."

# Analytics (опционально)
# NEXT_PUBLIC_GA_ID="G-..."

# Feature Flags
ENABLE_BACKGROUND_GENERATION="true"
ENABLE_VOICE_CLONING="false"
ENABLE_BATCH_PROCESSING="true"

# Limits
MAX_VIDEO_LENGTH_SECONDS="60"
MAX_TEXT_LENGTH="500"
MAX_VIDEOS_PER_USER_PER_DAY="20"
MAX_FILE_SIZE_MB="10"

# Video Processing
DEFAULT_VIDEO_FORMAT="VERTICAL"
DEFAULT_VIDEO_QUALITY="1080p"
FFMPEG_THREADS="4"

# Cleanup
AUTO_DELETE_TEMP_FILES="true"
TEMP_FILES_MAX_AGE_HOURS="24"
