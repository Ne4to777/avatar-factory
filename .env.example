# Database Configuration
DATABASE_URL="postgresql://avatar:avatar_password@localhost:5432/avatar_factory"
POSTGRES_USER=avatar
POSTGRES_PASSWORD=avatar_password
POSTGRES_DB=avatar_factory
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage (S3/MinIO) - use either S3_* or MINIO_* prefix (S3_* takes precedence)
S3_ENDPOINT=localhost
S3_PORT=9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=avatar-videos
S3_USE_SSL=false
S3_REGION=us-east-1

# Alternative MINIO_* prefix (legacy, will be auto-detected when S3_* not set)
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin123
# MINIO_BUCKET=avatar-videos
# MINIO_USE_SSL=false

# GPU Worker Configuration
GPU_SERVER_URL=http://192.168.1.100:8001
GPU_API_KEY=your-secret-gpu-key-change-this
GPU_TIMEOUT_MS=300000

# Application Configuration
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Temporary Files
TEMP_DIR=/tmp/avatar-factory

# Logging
LOG_LEVEL=INFO
