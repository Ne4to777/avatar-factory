{
  "name": "avatar-factory",
  "version": "1.0.0",
  "description": "Open-source video generation with talking avatars",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "worker": "tsx watch workers/video-worker.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:ps": "docker-compose ps",
    "setup": "npm run docker:up && sleep 5 && npm run prisma:migrate",
    "test": "npm run test:basic && npm run test:api",
    "test:basic": "tsx test-basic.ts",
    "test:api": "tsx test-api-full.ts",
    "clean": "rm -rf .next node_modules/.cache",
    "clean:all": "npm run clean && rm -rf node_modules",
    "health": "curl -s http://localhost:3000/api/health | jq || echo 'Server not running'",
    "install:full": "npm install && npm run docker:up && sleep 5 && npm run prisma:generate && npm run prisma:migrate && npm run test:basic",
    "start:dev": "concurrently \"npm run dev\" \"npm run worker\"",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "next": "^14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "@prisma/client": "^5.9.0",
    "prisma": "^5.9.0",
    "bullmq": "^5.1.0",
    "ioredis": "^5.3.2",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1",
    "@aws-sdk/client-s3": "^3.499.0",
    "@aws-sdk/s3-request-presigner": "^3.499.0",
    "fluent-ffmpeg": "^2.1.2",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "axios": "^1.6.5",
    "zod": "^3.22.4",
    "nanoid": "^5.0.4",
    "date-fns": "^3.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0",
    "lucide-react": "^0.312.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "framer-motion": "^10.18.0",
    "sonner": "^1.3.1",
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/fluent-ffmpeg": "^2.1.24",
    "tsx": "^4.7.0",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.33",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
